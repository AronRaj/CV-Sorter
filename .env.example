# CV Sorter — Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to version control

# --- API Key (required) ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Model configuration ---
# Shortlist agent: Ollama llama3.1:8b (local, free)
# JD extraction:   Ollama gemma2:9b   (local, free)
# Scorer agent:    Claude Sonnet      (API — set ANTHROPIC_API_KEY)
# Report agent:    Claude Sonnet      (API — same key)
# These are fixed architectural decisions, not runtime options.

# --- Output ---
OUTPUT_PATH=src/results/ranked_output.json

# --- PDF Parser ---
# "pymupdf"  — default, fast, handles digital PDFs + tables, LLM-ready markdown output
# "paddle"   — post-MVP, handles scanned PDFs, requires separate PaddleOCR install
PDF_PARSER=pymupdf

# --- LangChain / LangSmith tracing ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=cv-sorter-agents
