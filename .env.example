# CV Sorter — Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to version control

# --- LLM Provider Keys ---
# Add at least one. The others can be left blank.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# --- Groq Model ---
# Which model to use when provider is "groq"
GROQ_MODEL=llama-3.3-70b-versatile

# --- Defaults ---
# Which provider to use when --provider flag is not passed
DEFAULT_PROVIDER=groq

# Output path for ranked results
OUTPUT_PATH=results/ranked_output.json

# --- PDF Parser ---
# "pymupdf"  — default, fast, handles digital PDFs + tables, LLM-ready markdown output
# "paddle"   — post-MVP, handles scanned PDFs, requires separate PaddleOCR install
PDF_PARSER=pymupdf
