# CV Sorter — Environment Variables
# Copy this file to .env and fill in your keys, or pass --api-key to main.py
# Never commit real API keys to version control

# --- API Key (required for scoring and report generation) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Output ---
OUTPUT_PATH=results/ranked_output.json

# --- PDF Parser ---
# "pymupdf" — default, fast, handles digital PDFs + tables, LLM-ready markdown output
PDF_PARSER=pymupdf

# --- LangChain / LangSmith tracing (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=cv-sorter-agents
